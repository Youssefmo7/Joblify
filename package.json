    "@vue/cli-plugin-babel": "^5.0.9",
    "@vue/cli-plugin-eslint": "^5.0.9",
    "@vue/cli-service": "^5.0.9",
    "@tailwindcss/postcss": "^4.1.13",
    "@vue/compiler-sfc": "^3.5.30",
    "autoprefixer": "^10.4.27",
    "daisyui": "^5.5.19",
    "eslint": "^8.57.1",
    "eslint-plugin-vue": "^9.33.0",
